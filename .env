# VITE_API_BASE_URL=http://i2c20wv92gd8pqui6lxq7qq2.204.168.204.48.sslip.io/api/v1
VITE_API_BASE_URL=http://i2c20wv92gd8pqui6lxq7qq2.204.168.204.48.sslip.io/api/v1  

# LIFF — คัดลอก LIFF ID จาก LINE Developers > แชนเนลที่ถูกต้อง > แท็บ "LIFF" เท่านั้น
# ถ้าได้ 404 "LIFF app was not found" แปลว่า ID นี้ไม่มีในแชนเนลที่คุณใช้ (แยก SNM vs SKM / พิมพ์ผิด)
# Endpoint URL ใน Console ต้องเป็น URL ที่เปิดแอปจริง (ไม่ใช่ liff-default-*.html)
VITE_LIFF_ID=2009827789-q1MdaBFg

# Bill Payment QR (กรุงศรี suffix 01) — Ref1 = เลข ปชช. จากโปรไฟล์, Ref2 = เลขที่สัญญา
VITE_BILL_PAYMENT_TAX_ID=0355559000041
VITE_BILL_PAYMENT_BANK_SUFFIX=01
# true = ยอดท้ายสตริงเป็น 0 ให้กรอกในแอปธนาคาร | false = ฝังยอดค้างชำระเป็นสตางค์
VITE_BILL_PAYMENT_USE_ZERO_AMOUNT=true
