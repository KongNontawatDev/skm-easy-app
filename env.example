# App Configuration
VITE_APP_NAME=SKM Easy App
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=แอปพลิเคชันสำหรับการผ่อนชำระรถยนต์

# API Configuration
VITE_API_BASE_URL=https://api.example.com
VITE_API_TIMEOUT=10000

# LINE LIFF (ช่อง SKM EASY APP — คัดลอก LIFF ID จาก Console แท็บ "Web app settings")
# Developing:  2009827789-q1MdeBFg
# Review:      2009827790-8hN8PPpK
# Published:   2009827791-zTbkcLDE
VITE_LIFF_ID=2009827789-q1MdeBFg
#
# --- บังคับใน LINE Developers Console (ทำมือครั้งเดียว) ---
# 1. เปิดแชนเนล > Web app settings (หรือแท็บ LIFF)
# 2. แก้ "Endpoint URL" ของสภาพแวดล้อมที่ใช้ (Developing / Published) จาก
#    https://developers.line.biz/assets/liff-default-*.html
#    เป็น URL ต้นทางของแอปนี้ที่เปิดในเบราว์เซอร์จริง เช่น
#    - พัฒนาในเครื่อง: http://localhost:5173/
#    - ทดสอบภายนอก LINE: https://xxxx.ngrok-free.app/ (แนะนำ https)
# 3. URL นี้ต้องเป็น prefix ของทุก path ที่เรียก liff.init() (ดูเอกสาร LINE LIFF endpoint URL)
# ถ้าไม่แก้ Endpoint ให้ตรงกับแอป liff.init / liff.login จะไม่ทำงาน
#
# --- ถ้า Network ขึ้น 404: "LIFF app '...' was not found" ---
# - ค่า VITE_LIFF_ID ไม่ตรงกับ LIFF ที่มีจริงในแชนเนลนี้ (พิมพ์ผิด / คัดลอกจากแชนเนลอื่น / รูปแคปไม่ใช่ของโปรเจกต์เดียวกัน)
# - แชนเนลแรกอาจเป็น SNM (Channel ID 2003882778) แชนเนลอีกอันเป็น SKM (2009827789) — LIFF ID ต้องมาจาก **แชนเนลเดียวกับที่คุณใช้งาน**
# - แก้: LINE Developers → เลือก Provider + Channel ที่ถูก → แท็บ "LIFF" → คัดลอก LIFF ID จากรายการ (หรือจากลิงก์ https://miniapp.line.me/xxxx-xxxx)
# - ทดสอบ: เปิด https://miniapp.line.me/<LIFF_ID> ในเบราว์เซอร์ ถ้า LINE บอกไม่พบแอป แปลว่า ID ยังผิด

# Environment
VITE_NODE_ENV=development

# Bill Payment QR (มาตรฐานสตริง |TAX13+SUFFIX\rRef1\rRef2\rAmount — กรุงศรี suffix 01)
# Ref1 = เลขบัตร ปชช. จากโปรไฟล์ /me/profile, Ref2 = เลขที่สัญญา (CONTNO)
VITE_BILL_PAYMENT_TAX_ID=0355559000041
VITE_BILL_PAYMENT_BANK_SUFFIX=01
# true = ยอดท้ายสตริงเป็น 0 ให้ลูกค้ากรอกในแอปธนาคาร | false = ฝังยอดรวมค้างชำระเป็นสตางค์
VITE_BILL_PAYMENT_USE_ZERO_AMOUNT=true

# Features
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true
VITE_ENABLE_DEVTOOLS=true

# External Services
VITE_GOOGLE_ANALYTICS_ID=
VITE_SENTRY_DSN=

# PWA Configuration
VITE_PWA_NAME=SKM Easy App
VITE_PWA_SHORT_NAME=SKM App
VITE_PWA_DESCRIPTION=แอปพลิเคชันสำหรับการผ่อนชำระรถยนต์
VITE_PWA_THEME_COLOR=#EC1B2E
VITE_PWA_BACKGROUND_COLOR=#ffffff
